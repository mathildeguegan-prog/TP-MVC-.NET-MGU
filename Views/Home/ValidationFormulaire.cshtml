@{
    ViewData["HeaderTitle"] = "Page de validation";
}
@model TPLOCAL1.Models.FormModel


@section Menu {
    <ul>
        <li><a href="/Home/Index">Accueil</a></li>
        <li><a href="/Home/Index/OpinionList">Liste avis</a></li>
    </ul>
}

<section>

    <p>
        Votre formulaire a été pris en compte
    </p>


    <table border="1">
        <tr>
            <th colspan="2">Informations personnelles</th>
        </tr>

        <tr>
            <td>Nom</td>
            <td>@Model.Nom</td>
        </tr>

        <tr>
            <td>Prénom</td>
            <td>@Model.Prenom</td>
        </tr>

        <tr>
            <td>Genre</td>
            <td>@Model.Genre</td>
        </tr>

        <tr>
            <td>Adresse</td>
            <td>@Model.Adresse</td>
        </tr>

        <tr>
            <td>Code postal</td>
            <td>@Model.CodePostal</td>
        </tr>

        <tr>
            <td>Ville</td>
            <td>@Model.Ville</td>
        </tr>

        <tr>
            <td>Email</td>
            <td>@Model.Email</td>
        </tr>

    </table>

    <br />

    <table border="1">
        <tr>
            <th colspan="2">Informations formation</th>
        </tr>

        <tr>
            <td>Date début</td>
            <td>@Model.DateFormation.ToString("dd/MM/yyyy")</td>
        </tr>

        <tr>
            <td>Type formation</td>
            <td>@Model.TypeFormation</td>
        </tr>
    </table>

    <br />

    <table border="1">
        <tr>
            <th colspan="2">Avis formation</th>
        </tr>

        <tr>
            <td>Cobol</td>
            <td>@Model.AvisCobol</td>
        </tr>

        <tr>
            <td>C#</td>
            <td>@Model.AvisCSharp</td>
        </tr>
    </table>

</section>


